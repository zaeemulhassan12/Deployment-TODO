<!DOCTYPE html>
<html>
<head>
    <title>Edit Todo</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="container">

    <h1>✏️ Edit Todo</h1>

    <form action="/update/<%= todo.id %>" method="POST">

        <input
            type="text"
            name="task"
            value="<%= todo.task %>"
            required
        >

        <select name="priority">

            <option 
                value="Low"
                <%= todo.priority === 'Low' ? 'selected' : '' %>>
                Low
            </option>

            <option 
                value="Medium"
                <%= todo.priority === 'Medium' ? 'selected' : '' %>>
                Medium
            </option>

            <option 
                value="High"
                <%= todo.priority === 'High' ? 'selected' : '' %>>
                High
            </option>

        </select>

        <button type="submit">
            Update
        </button>

    </form>

    <a class="back-btn" href="/">
        ← Back Home
    </a>

</div>

</body>
</html>