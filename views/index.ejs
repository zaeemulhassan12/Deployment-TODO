<!DOCTYPE html>
<html>
<head>
    <title>Smart Todo App</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="container">

    <h1>ZEO TODO</h1>

    <form action="/add" method="POST">

        <input 
            type="text" 
            name="task" 
            placeholder="Enter your task..."
            required
        >

        <select name="priority">
            <option value="Low">Low</option>
            <option value="Medium" selected>Medium</option>
            <option value="High">High</option>
        </select>

        <button type="submit">
            Add
        </button>

    </form>

    <ul class="todo-list">

        <% todos.forEach(todo => { %>

            <li class="todo-item">

                <div class="todo-top">

                    <div class="task <%= todo.completed ? 'completed' : '' %>">

                        <%= todo.task %>

                    </div>

                    <div class="priority <%= todo.priority.toLowerCase() %>">

                        <%= todo.priority %>

                    </div>

                </div>

                <div class="actions">

                    <% if(!todo.completed) { %>

                        <a 
                            class="complete-btn"
                            href="/complete/<%= todo.id %>">
                            Complete
                        </a>

                    <% } %>

                    <a 
                        class="edit-btn"
                        href="/edit/<%= todo.id %>">
                        Edit
                    </a>

                    <a 
                        class="delete-btn"
                        href="/delete/<%= todo.id %>">
                        Delete
                    </a>

                </div>

            </li>

        <% }) %>

    </ul>

</div>

</body>
</html>